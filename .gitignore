# Per-developer config — contains your local SSH key path; never commit.
# config*.json also catches per-node configs (e.g. config.nodeb.json).
config*.json
!config.example.json

# Secrets — the SSH private key must never end up in the repo/bundle.
*.pem
*.key
*.ppk

# Runtime logs (JSONL trace of every tool call; one per config in multi-node).
*.log

# Python bytecode cache.
__pycache__/
*.pyc
